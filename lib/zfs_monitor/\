defmodule ZFSMonitor.Application do
  use Application
  require Logger

  @impl true
  def start(_type, _args) do
    children = [
      {ZFSMonitor.Cache, [interval: 5_000]},
      {GRPC.Server.Supervisor, endpoint: ZFSMonitor.Endpoint, port: 50051, start_server: true}
    ]

    opts = [strategy: :one_for_one, name: ZFSMonitor.Supervisor]
    Logger.info("Starting ZFS Monitor on port 50051")
    Supervisor.start_link(children, opts)
  end
end

defmodule ZFSMonitor.Endpoint do
  use GRPC.Endpoint

  intercept GRPC.Logger.Server
  run ZFSMonitor.GRPC.Server
end